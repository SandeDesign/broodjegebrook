rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ────────────────────────────────────────────────────────────────
    // DEVELOPMENT MODE: alles open
    // TODO: vervang met fijnmazige rules vóór live-gang
    // ────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
