{
  "name": "eufraat",
  "version": "0.1.0",
  "private": true,
  "description": "Eufraat eigen bestelplatform — klantsite + staff-app + Firebase backend",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "emulators": "firebase emulators:start --import=./firebase/.seed --export-on-exit=./firebase/.seed",
    "seed": "tsx firebase/functions/scripts/seedMenu.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
